#ifndef PROJECT_VERSION_H
#define PROJECT_VERSION_H

/* =========================
   Version Macros
   ========================= */

/* If not using CMake, fallback to manual defines */
#ifndef PROJECT_VERSION_MAJOR
#  define PROJECT_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#endif

#ifndef PROJECT_VERSION_MINOR
#  define PROJECT_VERSION_MINOR @PROJECT_VERSION_MINOR@
#endif

#ifndef PROJECT_VERSION_PATCH
#  define PROJECT_VERSION_PATCH @PROJECT_VERSION_PATCH@
#endif

/* String form */
#ifndef PROJECT_VERSION_STRING
#  define PROJECT_VERSION_STRING "@PROJECT_VERSION@"
#endif

/* Encoded version number: vX.Y.Z -> 0xXXYYZZ */
#define PROJECT_VERSION_HEX \
    ((PROJECT_VERSION_MAJOR << 16) | (PROJECT_VERSION_MINOR << 8) | (PROJECT_VERSION_PATCH))

/* Check if version >= (major.minor.patch) */
#define PROJECT_VERSION_CHECK(major, minor, patch) \
    (PROJECT_VERSION_MAJOR > (major) || \
    (PROJECT_VERSION_MAJOR == (major) && PROJECT_VERSION_MINOR > (minor)) || \
    (PROJECT_VERSION_MAJOR == (major) && PROJECT_VERSION_MINOR == (minor) && \
     PROJECT_VERSION_PATCH >= (patch)))

#endif /* PROJECT_VERSION_H */
